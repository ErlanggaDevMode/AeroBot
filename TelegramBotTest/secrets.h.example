#ifndef SECRETS_H
#define SECRETS_H

// WiFi Credentials
#define WIFI_SSID "YOUR_WIFI_SSID"
#define WIFI_PASSWORD "YOUR_WIFI_PASSWORD"

// Next.js Backend Connection Configuration
// Replace with your actual public Vercel domain when deployed (omit https://)
#define BACKEND_HOST "your-aerobot-app.vercel.app"
#define BACKEND_PATH "/api/device/upload"
#define DEVICE_ID "ESP32-001"

// Device API Authentication Key (MUST match the key in web/.env.local)
#define ESP32_API_KEY "your_api_key_here"

// GSM GPRS cellular configuration (Default is standard 'internet' APN)
#define GSM_APN "internet"
#define GSM_USER ""
#define GSM_PASS ""

#endif
